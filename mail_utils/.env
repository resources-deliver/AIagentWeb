# SMTP邮件服务配置
# 请根据您的邮件服务商配置以下参数

# SMTP服务器地址
# QQ邮箱: smtp.qq.com
# Gmail: smtp.gmail.com
# 163邮箱: smtp.163.com
SMTP_SERVER=smtp.qq.com

# SMTP服务器端口
# 通常使用587（TLS）或465（SSL）
SMTP_PORT=587

# SMTP登录用户名（通常是您的邮箱地址）
SMTP_USERNAME=y20040512@qq.com

# SMTP登录密码（注意：不是邮箱登录密码，而是授权码）
# QQ邮箱需要在设置中生成授权码
SMTP_PASSWORD=wftaegqdxwpndeca

# 发件人邮箱地址
FROM_EMAIL=y20040512@qq.com

# 发件人显示名称
FROM_NAME=AI数字人助手

# Ollama服务地址
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Edge-TTS语音参数
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
EDGE_TTS_PITCH=+0Hz

# 服务器配置
HOST=127.0.0.1
PORT=3000